var S={};
L.forEach(function(l){S[l.id]={};});

function letters(){return['A','B','C','D'];}

function buildSidebar(){
  var sb=document.getElementById('sbbtns');
  L.forEach(function(l,i){
    var b=document.createElement('button');
    b.className='lbtn'+(i===0?' active':'');
    b.dataset.lid=l.id;
    b.innerHTML='<span class="lnum">'+l.id+'</span><span style="flex:1">'+l.title+'</span><span class="lscore" id="ls-'+l.id+'"></span>';
    b.addEventListener('click',function(){switchL(l.id);});
    sb.appendChild(b);
  });
}

function switchL(lid){
  document.querySelectorAll('.lbtn').forEach(function(b){b.classList.remove('active');});
  document.querySelector('.lbtn[data-lid="'+lid+'"]').classList.add('active');
  document.querySelectorAll('.lsec').forEach(function(s){s.classList.remove('active');});
  document.getElementById('lsec-'+lid).classList.add('active');
  updPb(lid);
}

function buildContent(){
  var ca=document.getElementById('ca');
  L.forEach(function(l){
    var sec=document.createElement('div');
    sec.className='lsec'+(l.id===1?' active':'');
    sec.id='lsec-'+l.id;
    sec.innerHTML=
      '<div class="lhead">'+
        '<h2><em>Lecture '+l.id+':</em> '+l.title+'</h2>'+
        '<span class="mbadge">'+l.questions.length+' Questions</span>'+
      '</div>'+
      '<div class="pbwrap"><div class="pb" id="pb-'+l.id+'"></div></div>'+
      '<div class="qarea">'+
        '<div class="summary" id="sum-'+l.id+'">'+
          '<div><div class="slabel">Score</div><div class="snum" id="sn-'+l.id+'">0</div><div class="spct" id="sp-'+l.id+'">of '+l.questions.length+'</div></div>'+
          '<div class="sbreakdown">'+
            '<div class="sbitem"><div class="sbnum sbc" id="sc-'+l.id+'">0</div><div class="sblbl">Correct</div></div>'+
            '<div class="sbitem"><div class="sbnum sbw" id="sw-'+l.id+'">0</div><div class="sblbl">Wrong</div></div>'+
          '</div>'+
          '<button class="rbtn" onclick="resetL('+l.id+')">&#8635; Reset</button>'+
        '</div>'+
        '<div id="qs-'+l.id+'"></div>'+
      '</div>';
    ca.appendChild(sec);
    buildQs(l);
  });
}

function buildQs(l){
  var c=document.getElementById('qs-'+l.id);
  c.innerHTML='';
  l.questions.forEach(function(q,qi){
    var card=document.createElement('div');
    card.className='qcard';
    card.id='qc-'+l.id+'-'+qi;
    var LL=letters();
    var opts=q.o.map(function(opt,oi){
      return '<button class="obtn" id="ob-'+l.id+'-'+qi+'-'+oi+'" onclick="answer('+l.id+','+qi+','+oi+')"><span class="oletter">'+LL[oi]+'</span>'+opt+'</button>';
    }).join('');
    card.innerHTML=
      '<div class="qhdr"><span class="qnum">Q'+(qi+1)+'</span><span class="qtxt">'+q.q+'</span></div>'+
      '<div class="opts">'+opts+'</div>'+
      '<div class="fb" id="fb-'+l.id+'-'+qi+'"></div>';
    c.appendChild(card);
  });
}

function answer(lid,qi,chosen){
  if(S[lid][qi]!==undefined)return;
  var l=L.find(function(x){return x.id===lid;});
  var correct=l.questions[qi].a;
  var ok=chosen===correct;
  S[lid][qi]={chosen:chosen,correct:ok};

  var cb=document.getElementById('ob-'+lid+'-'+qi+'-'+chosen);
  cb.className='obtn '+(ok?'ok':'bad');

  if(!ok){
    var corb=document.getElementById('ob-'+lid+'-'+qi+'-'+correct);
    corb.className='obtn show';
  }

  for(var i=0;i<l.questions[qi].o.length;i++){
    document.getElementById('ob-'+lid+'-'+qi+'-'+i).disabled=true;
  }

  var fb=document.getElementById('fb-'+lid+'-'+qi);
  if(ok){
    fb.textContent='✓ Correct!';
    fb.className='fb ok';
    document.getElementById('qc-'+lid+'-'+qi).classList.add('ok');
  }else{
    fb.textContent='✗ Incorrect — Correct answer: '+letters()[correct]+') '+l.questions[qi].o[correct];
    fb.className='fb bad';
    document.getElementById('qc-'+lid+'-'+qi).classList.add('bad');
  }

  updPb(lid);
  updGlobal();
}

function updPb(lid){
  var l=L.find(function(x){return x.id===lid;});
  var ans=Object.keys(S[lid]).length;
  var cor=Object.values(S[lid]).filter(function(v){return v.correct;}).length;
  var wrong=ans-cor;
  var pct=Math.round((ans/l.questions.length)*100);

  document.getElementById('pb-'+lid).style.width=pct+'%';

  if(ans>0){
    document.getElementById('sum-'+lid).classList.add('vis');
    document.getElementById('sn-'+lid).textContent=cor;
    document.getElementById('sp-'+lid).textContent='of '+ans+' answered';
    document.getElementById('sc-'+lid).textContent=cor;
    document.getElementById('sw-'+lid).textContent=wrong;
  }else{
    document.getElementById('sum-'+lid).classList.remove('vis');
  }

  var ls=document.getElementById('ls-'+lid);
  ls.textContent=ans>0?(cor+'/'+l.questions.length):'';
}

function updGlobal(){
  var ta=0,tc=0;
  L.forEach(function(l){
    ta+=Object.keys(S[l.id]).length;
    tc+=Object.values(S[l.id]).filter(function(v){return v.correct;}).length;
  });
  document.getElementById('ta').textContent=ta;
  document.getElementById('tc').textContent=tc;
}

function resetL(lid){
  S[lid]={};
  var l=L.find(function(x){return x.id===lid;});
  buildQs(l);
  updPb(lid);
  updGlobal();
}

(function(){
  var total=L.reduce(function(s,l){return s+l.questions.length;},0);
  document.getElementById('tq').textContent=total;
  buildSidebar();
  buildContent();
})();
</script>

